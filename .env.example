# Supabase (get these from your Supabase project dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Generate your own keys - never share the service_role key
# NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key (if needed, keep secret!)

# Rate limiting (optional - get from Upstash Redis free tier)
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token